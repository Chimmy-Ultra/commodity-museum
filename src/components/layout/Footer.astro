---
import { wings } from '@data/wings';
import { getTotalRoomCount } from '@lib/museum';

const totalRooms = getTotalRoomCount();
---

<footer class="mt-24 border-t border-museum-border bg-museum-bg">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- About -->
      <div>
        <h3 class="font-display text-lg text-museum-accent">大宗商品博物館</h3>
        <p class="mt-2 text-sm leading-relaxed text-museum-text-secondary">
          {totalRooms} 間展室，橫跨 CME Group 與 ICE 兩大交易所，
          從鬱金香狂熱到 WTI 負油價，帶你走進大宗商品的傳奇世界。
        </p>
      </div>

      <!-- Wings -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-museum-text-secondary">展館</h4>
        <ul class="mt-3 space-y-2">
          {wings.map((wing) => (
            <li>
              <a
                href={`/${wing.slug}/`}
                class="text-sm text-museum-text-secondary transition-colors hover:text-museum-accent"
              >
                {wing.icon} {wing.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-museum-text-secondary">資訊</h4>
        <ul class="mt-3 space-y-2">
          <li>
            <a href="/about" class="text-sm text-museum-text-secondary transition-colors hover:text-museum-accent">
              關於博物館
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-museum-border pt-6 text-center text-xs text-museum-text-secondary">
      <p>大宗商品博物館 Commodity Museum &copy; {new Date().getFullYear()}</p>
    </div>
  </div>
</footer>
