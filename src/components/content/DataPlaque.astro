---
interface Props {
  exchange: string;
  year: number;
  contractSize: string;
  deliveryPoint?: string;
  tradingMonths?: string;
  tickerSymbol?: string;
}

const { exchange, year, contractSize, deliveryPoint, tradingMonths, tickerSymbol } = Astro.props;

const fields = [
  { label: '交易所', value: exchange },
  { label: '上市年份', value: String(year) },
  { label: '合約規格', value: contractSize },
  ...(deliveryPoint ? [{ label: '交割地點', value: deliveryPoint }] : []),
  ...(tradingMonths ? [{ label: '交易月份', value: tradingMonths }] : []),
  ...(tickerSymbol ? [{ label: '代碼', value: tickerSymbol }] : []),
];
---

<div class="my-8 overflow-hidden rounded-lg border border-museum-accent/30 bg-museum-plaque">
  <!-- Plaque header -->
  <div class="border-b border-museum-accent/20 bg-museum-accent/5 px-6 py-3">
    <h4 class="font-display text-sm font-semibold uppercase tracking-widest text-museum-accent">
      合約資訊 Contract Specifications
    </h4>
  </div>
  <!-- Fields -->
  <div class="grid gap-px bg-museum-border sm:grid-cols-2">
    {fields.map((field) => (
      <div class="bg-museum-plaque px-6 py-4">
        <dt class="text-xs font-semibold uppercase tracking-wider text-museum-text-secondary">
          {field.label}
        </dt>
        <dd class="mt-1 font-mono text-lg text-museum-text">{field.value}</dd>
      </div>
    ))}
  </div>
</div>
