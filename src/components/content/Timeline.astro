---
interface TimelineEvent {
  year: string;
  text: string;
}

interface Props {
  events: TimelineEvent[];
}

const { events } = Astro.props;
---

<div class="relative my-8 ml-4 border-l-2 border-museum-border pl-8">
  {events.map((event, i) => (
    <div class="relative mb-8 last:mb-0">
      <!-- Dot -->
      <div class="absolute -left-[2.55rem] top-1 h-3 w-3 rounded-full border-2 border-museum-accent bg-museum-bg" />
      <!-- Year -->
      <span class="font-mono text-sm font-semibold text-museum-accent">{event.year}</span>
      <!-- Text -->
      <p class="mt-1 text-museum-text-secondary">{event.text}</p>
    </div>
  ))}
</div>
