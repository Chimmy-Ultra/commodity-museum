---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  captionEn?: string;
  credit?: string;
  creditUrl?: string;
  width?: number;
  float?: 'left' | 'right';
  historical?: boolean;
}

const { src, alt, caption, captionEn, credit, creditUrl, width = 720, float, historical = false } = Astro.props;

const wrapperClass = [
  'my-8 overflow-hidden rounded-lg border border-museum-border bg-museum-wall',
  float === 'left' ? 'float-left mr-6 mb-4 max-w-xs' : '',
  float === 'right' ? 'float-right ml-6 mb-4 max-w-xs' : '',
].filter(Boolean).join(' ');
---

<figure class={wrapperClass}>
  <Image
    src={src}
    alt={alt}
    width={width}
    style="max-height: 24rem; width: auto; max-width: 100%;"
    class={`mx-auto${historical ? ' museum-sepia' : ''}`}
  />
  {(caption || captionEn || credit) && (
    <figcaption class="border-t border-museum-border bg-museum-plaque px-5 py-3">
      {caption && (
        <p class="font-display text-sm font-medium text-museum-text">{caption}</p>
      )}
      {captionEn && (
        <p class="mt-0.5 text-xs italic text-museum-text-secondary">{captionEn}</p>
      )}
      {credit && (
        <p class="mt-1 text-xs text-museum-text-secondary/60">
          {'來源：'}
          {creditUrl
            ? <a href={creditUrl} target="_blank" rel="noopener noreferrer" class="underline hover:text-museum-accent">{credit}</a>
            : credit
          }
        </p>
      )}
    </figcaption>
  )}
</figure>
